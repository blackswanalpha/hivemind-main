{
  "name": "hivemind-main",
  "private": true,
  "version": "0.0.0",
  "description": "Convenience scripts that delegate to apps/desktop so common dev commands work from the workspace root.",
  "scripts": {
    "install:ui": "pnpm -C apps/desktop install",
    "dev": "pnpm -C apps/desktop dev",
    "tauri": "pnpm -C apps/desktop tauri",
    "tauri:dev": "pnpm -C apps/desktop tauri dev",
    "tauri:build": "pnpm -C apps/desktop tauri build",
    "build": "pnpm -C apps/desktop build",
    "typecheck": "pnpm -C apps/desktop typecheck",
    "preview": "pnpm -C apps/desktop preview"
  }
}
