{
  "productName": "hivemind",
  "version": "0.0.0",
  "identifier": "dev.hivemind.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HiveMind",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "AI-native desktop browser",
    "longDescription": "HiveMind is an AI-native desktop browser built on Tauri 2."
  }
}
